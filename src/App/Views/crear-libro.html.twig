{% extends 'layout/base.html.twig' %}
{% import 'macros/forms.html.twig' as forms %}

{% block title %}Crear Libro - PAWPrints{% endblock %}

{% block main %}
  <header>
    <h1>Agregar Nuevo Libro</h1>
    <p>Completá los datos para cargar el libro en el catálogo.</p>
  </header>

  <section class="Formulario">
    <h2>Datos del libro nuevo</h2>
    {% if errores.general is defined and errores.general is not empty %}
      <span class="error">{{ errores.general|escape }}</span>
    {% endif %}

    <form id="form-nuevo-libro" action="/crear-libro" method="POST" enctype="multipart/form-data" novalidate>

      <fieldset>
        <legend>Información del Libro</legend>

        {{ forms.input('titulo', 'Título', 'text', app.request.post('titulo')|default(''), errores.titulo|default(''), 'maxlength="60" required') }}

        {# Mapear las colecciones a un array de objetos simples con id y nombre para el macro #}
        {% set opcionesAutores = [] %}
        {% for autor in autores %}{% set opcionesAutores = opcionesAutores|merge([{'id': autor.fields.id, 'nombre': autor.fields.nombre}]) %}{% endfor %}
        {{ forms.select('autor_id', 'Autor', opcionesAutores, app.request.post('autor_id')|default(''), errores.autor_id|default(''), 'required') }}

        {% set opcionesGeneros = [] %}
        {% for genero in generos %}{% set opcionesGeneros = opcionesGeneros|merge([{'id': genero.fields.id, 'nombre': genero.fields.nombre}]) %}{% endfor %}
        {{ forms.select('genero_id', 'Género', opcionesGeneros, app.request.post('genero_id')|default(''), errores.genero_id|default(''), 'required') }}

        {% set opcionesEditoriales = [] %}
        {% for editorial in editoriales %}{% set opcionesEditoriales = opcionesEditoriales|merge([{'id': editorial.fields.id, 'nombre': editorial.fields.nombre}]) %}{% endfor %}
        {{ forms.select('editorial_id', 'Editorial', opcionesEditoriales, app.request.post('editorial_id')|default(''), errores.editorial_id|default(''), 'required') }}

        {% set opcionesIdiomas = [] %}
        {% for idioma in idiomas %}{% set opcionesIdiomas = opcionesIdiomas|merge([{'id': idioma.fields.id, 'nombre': idioma.fields.nombre}]) %}{% endfor %}
        {{ forms.select('idioma_id', 'Idioma', opcionesIdiomas, app.request.post('idioma_id')|default(''), errores.idioma_id|default(''), 'required') }}
        
        {{ forms.textarea('descripcion', 'Descripción', app.request.post('descripcion')|default(''), errores.descripcion|default(''), 'maxlength="1000" required') }}
      </fieldset>

      <fieldset>
        <legend>Inventario y portada</legend>

        {{ forms.input('precio', 'Precio', 'number', app.request.post('precio')|default(''), errores.precio|default(''), 'step="0.01" min="0" required') }}

        {{ forms.input('stock', 'Stock', 'number', app.request.post('stock')|default(''), errores.stock|default(''), 'step="1" min="0" required') }}

        <label>Imagen de portada</label>
        <section id="portada-uploader" class="paw-uploader-container"></section>
        {% if errores.imagen is defined %}
          <span class="error">{{ errores.imagen|escape }}</span>
        {% endif %}
      </fieldset>

      <button type="submit" class="btn-submit btn-primario">Agregar Libro</button>
    </form>
  </section>
{% endblock %}
