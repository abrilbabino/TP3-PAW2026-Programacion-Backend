<header class="Barra-navegacion">
    <figure class="header-logo">
      <img src="/assets/img/logo.png" alt="PAWPrints" />
    </figure>

    <form action="/buscar" method="GET" class="header-busqueda" data-paw-busquedas>
      <label for="busqueda" class="busqueda-label">Buscar en el sitio..</label>
      <span class="material-symbols-outlined busqueda-icono">search</span>
      <input
        type="search"
        id="busqueda"
        name="busqueda"
        value="{{ app.request.get('busqueda')|default('')|escape }}"
        placeholder="Buscar en el sitio..."
        class="busqueda-input"
        autocomplete="off"
      />
      <button type="submit" class="busqueda-btn">Buscar</button>
    </form>
    
    <nav class="menu-principal" id="paw-menu-root">
      <ul class="nav-lista">
        {% for item in menu %}
            <li class="{{ item.li_class|default('') }}">
                {% if item.type == 'link' %}
                    <a href="{{ item.href }}" class="nav-link {{ item.class|default('') }}">
                        <span class="material-symbols-outlined simbolos">{{ item.icon }}</span>
                        {{ item.name }}
                    </a>
                {% else %}
                    <label for="{{ item.for }}" class="nav-link">
                        <span class="material-symbols-outlined simbolos">{{ item.icon }}</span>
                        {{ item.name }}
                    </label>
                {% endif %}
            </li>
        {% endfor %}
    </ul>
  </nav>
</header>
