{% extends 'layout/base.html.twig' %}

{% block title %}Libro - {{ libro.fields.titulo }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/pawcarousel.css" />
{% endblock %}

{% block main %}
<article itemscope itemtype="https://schema.org/Book">
  <section class="detalle-libro">
      <figure>
          <img itemprop="image" src="/assets/img/{{ libro.fields.imagen|default('default.png') }}" alt="Portada {{ libro.fields.titulo }}" />
          <figcaption>
          <h2 itemprop="name">{{ libro.fields.titulo }}</h2>
          <span class="stock-mobile">Stock Disponible</span>
          </figcaption>
      </figure>
      <article class="descripcion-libro">
          <h2>Descripción</h2>
          <p itemprop="description">{{ libro.fields.descripcion }}</p>
          <h2>Autor</h2>
          <p itemprop="author" itemscope itemtype="https://schema.org/Person">
              <span itemprop="name">{{ autor.fields.nombre }}</span>
          </p>
      </article>
      <section class="compra-reserva" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="priceCurrency" content="ARS" />
          <p><strong>$<span itemprop="price">{{ libro.fields.precio }}</span></strong></p>
          <span class="stock-desktop">Stock Disponible</span>
          <form class="boton-agregarCarrito" action="/agregarCarrito" method="POST">
              <input type="hidden" name="libro_id" value="{{ libro.fields.id }}">
              <button type="submit">Agregar al Carrito</button>
          </form>
          <form class="boton-reservar" action="/reserva" method="GET">
              <input type="hidden" name="libro" value="{{ libro.fields.titulo }}">
              <button type="submit">Reservar Gratis</button>
          </form>
      </section>
  </section>
  <section class="descripcion-autor" itemprop="author" itemscope itemtype="https://schema.org/Person">
      <figure>
          <img itemprop="image" src="/assets/img/autor_{{ autor.fields.nombre }}.jpg" alt="Fotografía {{ autor.fields.nombre }}"/>
      </figure>
      <article>
          <h3 itemprop="name">{{ autor.fields.nombre }}</h3>
          <p itemprop="description">{{ autor.fields.biografia }}</p>
      </article>
  </section>
</article>

  <section class="libros-relacionados">
      <h2>Libros que te podrían gustar</h2>
      <section class="carrusel" data-paw-carousel data-paw-effect="slide">
          {% if relacionados is defined and relacionados is not empty %}
              {% for relacionado in relacionados %}
                  <article class="libro-relacionado tarjeta-libro">
                      <a href="/detalle?id={{ relacionado.libro.fields.id }}">
                          <figure>
                              <img src="/assets/img/{{ relacionado.libro.fields.imagen|default('default.png') }}" alt="{{ relacionado.libro.fields.titulo }}">
                          </figure>
                          <p class="tarjeta-titulo">{{ relacionado.libro.fields.titulo }}</p>
                          <p class="tarjeta-autor">{{ relacionado.autor_nombre }}</p>
                          <p class="tarjeta-precio">${{ relacionado.libro.fields.precio }}</p>
                      </a>
                  </article>
              {% endfor %}
          {% else %}
              <p>No hay libros relacionados en este momento</p>
          {% endif %}
      </section>
      <fieldset class="efectos-selector">
          <legend>Efecto de transición</legend>
          <button class="efecto-btn active" data-efecto="slide">Slide</button>
          <button class="efecto-btn" data-efecto="fade">Fade</button>
          <button class="efecto-btn" data-efecto="zoom">Zoom</button>
      </fieldset>
  </section>
{% endblock %}
